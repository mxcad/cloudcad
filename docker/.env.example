# CloudCAD 环境配置
# 复制此文件为 .env 并修改配置
# copy .env.example .env

# ============================================
# 数据库配置
# ============================================

# Prisma 连接字符串 (必须配置)
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://postgres:your-secure-password-here@postgres:5432/cloudcad

# 数据库详细配置
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your-secure-password-here
DB_DATABASE=cloudcad
DB_SSL=false
DB_MAX_CONNECTIONS=20
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=30000

# ============================================
# Redis 配置
# ============================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=100

# ============================================
# JWT 配置
# ============================================

# JWT 密钥 (必须修改! 至少 32 位随机字符串)
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=your-jwt-secret-at-least-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# 上传配置
# ============================================

# 最大上传文件大小 (字节), 默认 100MB
UPLOAD_MAX_SIZE=104857600
# 允许的文件类型
UPLOAD_ALLOWED_TYPES=.dwg,.dxf,.pdf,.png,.jpg,.jpeg
# 文件转换并发数（CPU 密集型，建议不超过 CPU 核心数）
UPLOAD_MAX_CONCURRENT=3
# 分片上传并发数（I/O 密集型，可以较高）
UPLOAD_CHUNK_MAX_CONCURRENT=5

# ============================================
# 存储路径配置 (容器内路径)
# 所有数据目录统一在 /app/data/ 下
# ============================================

# 文件数据目录
FILES_DATA_PATH=/app/data/files
# SVN 仓库目录
SVN_REPO_PATH=/app/data/svn-repo
# 上传目录
MXCAD_UPLOAD_PATH=/app/data/uploads
# 临时文件目录
MXCAD_TEMP_PATH=/app/data/temp
# MxCAD 转换程序路径 (Linux)
MXCAD_ASSEMBLY_PATH=/app/runtime/linux/mxcad/mxcadassembly
# 字体目录 (可选，不配置则使用默认路径)
MXCAD_FONTS_PATH=/app/runtime/linux/mxcad/fonts
# 前端字体目录 (nginx 静态资源)
FRONTEND_FONTS_PATH=/var/www/html/mxcadAppAssets/fonts

# ============================================
# 服务端口
# ============================================

# HTTP 端口（Nginx）
HTTP_PORT=80

# 后端 API 端口
API_PORT=3001

# 前端页面端口
FRONTEND_PORT=3000

# 配置中心端口
CONFIG_SERVICE_PORT=3002

# 协同服务端口
COOPERATE_PORT=3091

# ============================================
# 邮件服务配置
# ============================================

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM=CloudCAD <noreply@cloudcad.com>

# ============================================
# 前端配置
# ============================================

FRONTEND_URL=http://localhost

# ============================================
# 初始管理员账户 (仅在首次启动时创建)
# ============================================

INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=Admin123!