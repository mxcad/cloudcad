{
  "eval_id": 2,
  "eval_name": "add-permission-guard",
  "prompt": "我需要为 FileController 的删除接口添加权限控制，只有拥有 FILE_DELETE 权限的用户才能删除文件。请帮我实现。",
  "assertions": [
    {
      "name": "使用了正确的装饰器",
      "description": "应该使用 @RequireProjectPermission 装饰器",
      "check_type": "output_contains",
      "expected": "RequireProjectPermission"
    },
    {
      "name": "使用了正确的权限常量",
      "description": "应该使用 ProjectPermission.FILE_DELETE 常量",
      "check_type": "output_contains",
      "expected": "FILE_DELETE"
    },
    {
      "name": "提到了 Guard 配置",
      "description": "应该提到 RequireProjectPermissionGuard",
      "check_type": "output_contains",
      "expected": "RequireProjectPermissionGuard"
    }
  ]
}
