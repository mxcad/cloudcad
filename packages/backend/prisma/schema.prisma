generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  nickname  String?
  avatar    String?
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  status    UserStatus @default(INACTIVE)
  emailVerified    Boolean  @default(false)
  emailVerifiedAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联关系
  ownedNodes         FileSystemNode[] @relation("NodeOwner")
  projectMembers     ProjectMember[]
  auditLogs          AuditLog[]

  @@map("users")
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  category    RoleCategory @default(SYSTEM) // 角色类别
  level       Int          @default(0)      // 角色级别（用于权限继承）
  isSystem    Boolean      @default(false)  // 是否为系统角色（不可删除）
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // 关联关系
  users       User[]
  permissions RolePermission[]
  projectMembers ProjectMember[]

  @@index([category])
  @@map("roles")
}

model RolePermission {
  id          String   @id @default(cuid())
  roleId      String
  permission  Permission
  createdAt   DateTime @default(now())

  // 关联关系
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permission])
  @@map("role_permissions")
}

// ============ 文件系统统一模型 ============
model FileSystemNode {
  id          String   @id @default(cuid())
  name        String
  isFolder    Boolean  @default(false)  // true=文件夹, false=文件
  isRoot      Boolean  @default(false)  // true=项目根目录
  
  // 树形结构（自引用）
  parentId    String?
  parent      FileSystemNode?  @relation("NodeHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    FileSystemNode[] @relation("NodeHierarchy")
  
  // 文件专属字段（文件夹时为null）
  originalName String?   // 原始文件名
  path         String?   // 文件访问路径（如：/mxcad/file/xxx.dwg.mxweb）
  size         Int?      // 文件大小（字节）
  mimeType     String?   // MIME类型
  extension    String?   // 文件扩展名（.dwg, .dxf）
  fileStatus   FileStatus? // 文件状态
  fileHash     String?   // 文件SHA-256哈希值（用于去重）
  
  // 项目专属字段（仅根节点使用）
  description    String?          // 项目描述
  projectStatus  ProjectStatus?   // 项目状态

  // 外部参照相关字段（仅文件使用）
  hasMissingExternalReferences  Boolean @default(false)  // 是否有缺失的外部参照
  missingExternalReferencesCount Int    @default(0)      // 缺失的外部参照数量
  externalReferencesJson        String?                // 完整的外部参照信息（JSON格式）

  // 图库相关字段（仅文件使用）
  isInGallery      Boolean  @default(false)  // 是否在图库中
  galleryType      String?                   // 图库类型：'drawings' 或 'blocks'
  galleryFirstType Int?                      // 一级分类 ID
  gallerySecondType Int?                      // 二级分类 ID
  galleryThirdType  Int?                      // 三级分类 ID（可选）
  galleryLookNum   Int      @default(0)      // 浏览次数

  // 权限与审计
  ownerId     String
  owner       User     @relation("NodeOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime? // 软删除时间（回收站功能）
  deletedByCascade Boolean @default(false) // 是否因父节点删除而被自动删除

  // 关联关系
  projectMembers ProjectMember[]

  // 索引优化
  @@index([parentId])
  @@index([ownerId])
  @@index([isRoot])
  @@index([isFolder])
  @@index([deletedAt])
  @@map("file_system_nodes")
}

// ============ 项目成员模块 ============

// 项目成员（用户与项目的关联，使用系统角色）
model ProjectMember {
  id        String      @id @default(cuid())
  projectId String      // 项目ID
  userId    String      // 用户ID
  roleId    String      // 系统角色ID（关联到Role表）
  createdAt DateTime    @default(now())

  // 关联关系
  project   FileSystemNode @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role            @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([projectId, userId])
  @@index([userId])
  @@index([roleId])
  @@map("project_members")
}

model Asset {
  id          String     @id @default(cuid())
  name        String
  description String?
  category    String
  path        String
  thumbnail   String?
  size        Int
  mimeType    String
  status      AssetStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("assets")
}

model Font {
  id          String    @id @default(cuid())
  name        String
  family      String
  path        String
  size        Int
  status      FontStatus @default(ACTIVE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("fonts")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ============ 审计日志模块 ============

// 审计日志表
model AuditLog {
  id          String      @id @default(cuid())
  action      AuditAction // 操作类型
  resourceType ResourceType // 资源类型
  resourceId  String?     // 资源 ID
  userId      String      // 操作用户 ID
  details     String?     // 详细信息（JSON 格式）
  ipAddress   String?     // IP 地址
  userAgent   String?     // 用户代理
  success     Boolean     // 操作是否成功
  errorMessage String?    // 错误信息
  createdAt   DateTime    @default(now())

  // 关联关系
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

model UploadSession {
  id          String   @id @default(cuid())
  uploadId    String   @unique  // MinIO返回的上传ID
  storageKey  String   // 存储键名
  fileName    String   // 原始文件名
  fileSize    Int      // 文件总大小
  fileId      String?  // 关联的文件ID（完成后设置）
  projectId   String?  // 项目ID
  parentId    String?  // 父节点ID
  ownerId     String   // 上传者ID
  status      String   @default("INITIATED") // INITIATED, UPLOADING, COMPLETED, FAILED, ABORTED
  totalParts  Int?     // 总分片数
  uploadedParts Int    @default(0) // 已上传分片数
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("upload_sessions")
}

// ============ 图库模块 ============

// 图库分类
model GalleryType {
  id          Int      @id @default(autoincrement())
  pid         Int      @default(0)  // 父分类 ID，0 表示一级分类
  name        String
  status      Int      @default(1)  // 状态：1=启用，0=禁用
  galleryType String  // 图库类型：'drawings' 或 'blocks'
  ownerId     String   // 分类所有者 ID
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([pid])
  @@index([galleryType])
  @@index([ownerId])
  @@map("gallery_types")
}

// 枚举类型
enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Permission {
  // 用户权限
  USER_READ
  USER_WRITE
  USER_DELETE
  USER_ADMIN

  // 项目权限
  PROJECT_CREATE
  PROJECT_READ
  PROJECT_WRITE
  PROJECT_DELETE
  PROJECT_ADMIN
  PROJECT_MEMBER_MANAGE

  // 文件权限
  FILE_CREATE
  FILE_READ
  FILE_WRITE
  FILE_DELETE
  FILE_SHARE
  FILE_DOWNLOAD
  FILE_COMMENT
  FILE_PRINT
  FILE_COMPARE

  // 版本管理权限
  VERSION_READ
  VERSION_CREATE
  VERSION_DELETE
  VERSION_RESTORE

  // 字体管理权限
  FONT_MANAGE

  // 审图配置权限
  REVIEW_CONFIG

  // 回收站权限
  TRASH_MANAGE

  // 系统权限
  SYSTEM_ADMIN
  SYSTEM_MONITOR
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum FileStatus {
  UPLOADING
  PROCESSING
  COMPLETED
  FAILED
  DELETED
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum FontStatus {
  ACTIVE
  INACTIVE
  DELETED
}

// 审计操作类型
enum AuditAction {
  PERMISSION_GRANT
  PERMISSION_REVOKE
  ROLE_CREATE
  ROLE_UPDATE
  ROLE_DELETE
  USER_LOGIN
  USER_LOGOUT
  PROJECT_CREATE
  PROJECT_DELETE
  FILE_UPLOAD
  FILE_DOWNLOAD
  FILE_DELETE
  FILE_SHARE
  ADD_MEMBER
  UPDATE_MEMBER
  REMOVE_MEMBER
  TRANSFER_OWNERSHIP
  ACCESS_DENIED
}

// 资源类型
enum ResourceType {
  USER
  ROLE
  PERMISSION
  PROJECT
  FILE
  FOLDER
}

// 角色类别
enum RoleCategory {
  SYSTEM   // 系统角色（ADMIN, USER）
  PROJECT  // 项目角色（PROJECT_OWNER, PROJECT_ADMIN, PROJECT_MEMBER, PROJECT_EDITOR, PROJECT_VIEWER）
  CUSTOM   // 自定义角色
}