generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  nickname  String?
  avatar    String?
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  status    UserStatus @default(INACTIVE)
  emailVerified    Boolean  @default(false)
  emailVerifiedAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联关系
  ownedNodes         FileSystemNode[] @relation("NodeOwner")
  nodeAccesses       FileAccess[]
  galleryCollects    GalleryCollect[]

  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)  // 是否为系统角色（不可删除）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关联关系
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model RolePermission {
  id          String   @id @default(cuid())
  roleId      String
  permission  Permission
  createdAt   DateTime @default(now())

  // 关联关系
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permission])
  @@map("role_permissions")
}

// ============ 文件系统统一模型 ============
model FileSystemNode {
  id          String   @id @default(cuid())
  name        String
  isFolder    Boolean  @default(false)  // true=文件夹, false=文件
  isRoot      Boolean  @default(false)  // true=项目根目录
  
  // 树形结构（自引用）
  parentId    String?
  parent      FileSystemNode?  @relation("NodeHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    FileSystemNode[] @relation("NodeHierarchy")
  
  // 文件专属字段（文件夹时为null）
  originalName String?   // 原始文件名
  path         String?   // 文件访问路径（如：/mxcad/file/xxx.dwg.mxweb）
  size         Int?      // 文件大小（字节）
  mimeType     String?   // MIME类型
  extension    String?   // 文件扩展名（.dwg, .dxf）
  fileStatus   FileStatus? // 文件状态
  fileHash     String?   // 文件SHA-256哈希值（用于去重）
  
  // 项目专属字段（仅根节点使用）
  description    String?          // 项目描述
  projectStatus  ProjectStatus?   // 项目状态

  // 外部参照相关字段（仅文件使用）
  hasMissingExternalReferences  Boolean @default(false)  // 是否有缺失的外部参照
  missingExternalReferencesCount Int    @default(0)      // 缺失的外部参照数量
  externalReferencesJson        String?                // 完整的外部参照信息（JSON格式）

  // 权限与审计
  ownerId     String
  owner       User     @relation("NodeOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime? // 软删除时间（回收站功能）
  deletedByCascade Boolean @default(false) // 是否因父节点删除而被自动删除

  // 关联关系
  nodeAccesses FileAccess[]    @relation("NodeAccesses")
  galleryItems GalleryItem[]   @relation("GalleryItems")

  // 索引优化
  @@index([parentId])
  @@index([ownerId])
  @@index([isRoot])
  @@index([isFolder])
  @@index([deletedAt])
  @@map("file_system_nodes")
}

model FileAccess {
  id        String         @id @default(cuid())
  userId    String
  nodeId    String         // 关联到FileSystemNode
  role      FileAccessRole @default(VIEWER)
  createdAt DateTime       @default(now())

  // 关联关系
  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  node FileSystemNode   @relation("NodeAccesses", fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([userId, nodeId])
  @@map("file_accesses")
}

model Asset {
  id          String     @id @default(cuid())
  name        String
  description String?
  category    String
  path        String
  thumbnail   String?
  size        Int
  mimeType    String
  status      AssetStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("assets")
}

model Font {
  id          String    @id @default(cuid())
  name        String
  family      String
  path        String
  size        Int
  status      FontStatus @default(ACTIVE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("fonts")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model UploadSession {
  id          String   @id @default(cuid())
  uploadId    String   @unique  // MinIO返回的上传ID
  storageKey  String   // 存储键名
  fileName    String   // 原始文件名
  fileSize    Int      // 文件总大小
  fileId      String?  // 关联的文件ID（完成后设置）
  projectId   String?  // 项目ID
  parentId    String?  // 父节点ID
  ownerId     String   // 上传者ID
  status      String   @default("INITIATED") // INITIATED, UPLOADING, COMPLETED, FAILED, ABORTED
  totalParts  Int?     // 总分片数
  uploadedParts Int    @default(0) // 已上传分片数
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("upload_sessions")
}

// ============ 图库模块 ============

// 图库分类
model GalleryType {
  id          Int      @id @default(autoincrement())
  pid         Int      @default(0)  // 父分类 ID，0 表示一级分类
  name        String
  status      Int      @default(1)  // 状态：1=启用，0=禁用
  galleryType String  // 图库类型：'drawings' 或 'blocks'
  items       GalleryItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([pid])
  @@index([galleryType])
  @@map("gallery_types")
}

// 图库项目
model GalleryItem {
  id          String   @id @default(cuid())
  nodeId      String   @unique  // 关联到 FileSystemNode
  firstType   Int      // 一级分类 ID
  secondType  Int      // 二级分类 ID
  thirdType   Int?     // 三级分类 ID（可选）
  galleryType String   // 图库类型：'drawings' 或 'blocks'
  node        FileSystemNode @relation("GalleryItems", fields: [nodeId], references: [id], onDelete: Cascade)
  type        GalleryType @relation(fields: [secondType], references: [id])
  statistics  GalleryStatistics?
  collects    GalleryCollect[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([firstType])
  @@index([secondType])
  @@index([thirdType])
  @@index([galleryType])
  @@map("gallery_items")
}

// 图库统计
model GalleryStatistics {
  id        String   @id @default(cuid())
  itemId    String   @unique  // 关联 GalleryItem
  lookNum   Int      @default(0)  // 浏览次数
  likeNum   Int      @default(0)  // 收藏次数
  item      GalleryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("gallery_statistics")
}

// 图库收藏
model GalleryCollect {
  id        String   @id @default(cuid())
  itemId    String   // 关联 GalleryItem
  userId    String   // 收藏用户
  item      GalleryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([itemId, userId])
  @@index([itemId])
  @@index([userId])
  @@map("gallery_collects")
}

// 枚举类型
enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Permission {
  // 用户权限
  USER_READ
  USER_WRITE
  USER_DELETE
  USER_ADMIN

  // 项目权限
  PROJECT_CREATE
  PROJECT_READ
  PROJECT_WRITE
  PROJECT_DELETE
  PROJECT_ADMIN
  PROJECT_MEMBER_MANAGE

  // 文件权限
  FILE_CREATE
  FILE_READ
  FILE_WRITE
  FILE_DELETE
  FILE_SHARE
  FILE_DOWNLOAD

  // 系统权限
  SYSTEM_ADMIN
  SYSTEM_MONITOR
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum FileStatus {
  UPLOADING
  PROCESSING
  COMPLETED
  FAILED
  DELETED
}

enum FileAccessRole {
  OWNER      // 所有者：完全控制
  ADMIN      // 管理员：管理权限
  MEMBER     // 成员：可编辑
  EDITOR     // 编辑者：可编辑文件
  VIEWER     // 查看者：只读
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum FontStatus {
  ACTIVE
  INACTIVE
  DELETED
}
