generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  nickname  String?
  avatar    String?
  role      UserRole @default(USER)
  status    UserStatus @default(INACTIVE)
  emailVerified    Boolean  @default(false)
  emailVerifiedAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联关系
  projectMemberships ProjectMember[]
  ownedNodes         FileSystemNode[] @relation("NodeOwner")
  nodeAccesses       FileAccess[]

  @@map("users")
}

// ============ 文件系统统一模型 ============
model FileSystemNode {
  id          String   @id @default(cuid())
  name        String
  isFolder    Boolean  @default(false)  // true=文件夹, false=文件
  isRoot      Boolean  @default(false)  // true=项目根目录
  
  // 树形结构（自引用）
  parentId    String?
  parent      FileSystemNode?  @relation("NodeHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    FileSystemNode[] @relation("NodeHierarchy")
  
  // 文件专属字段（文件夹时为null）
  originalName String?   // 原始文件名
  path         String?   // MinIO存储路径
  size         Int?      // 文件大小（字节）
  mimeType     String?   // MIME类型
  extension    String?   // 文件扩展名（.dwg, .dxf）
  fileStatus   FileStatus? // 文件状态
  
  // 项目专属字段（仅根节点使用）
  description    String?          // 项目描述
  projectStatus  ProjectStatus?   // 项目状态
  
  // 权限与审计
  ownerId     String
  owner       User     @relation("NodeOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // 关联关系
  members      ProjectMember[] @relation("ProjectNodes")
  nodeAccesses FileAccess[]    @relation("NodeAccesses")
  
  // 索引优化
  @@index([parentId])
  @@index([ownerId])
  @@index([isRoot])
  @@index([isFolder])
  @@map("file_system_nodes")
}

model ProjectMember {
  id        String            @id @default(cuid())
  userId    String
  nodeId    String            // 关联到FileSystemNode（根节点）
  role      ProjectMemberRole @default(MEMBER)
  joinedAt  DateTime          @default(now())

  // 关联关系
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  node    FileSystemNode   @relation("ProjectNodes", fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([userId, nodeId])
  @@map("project_members")
}

model FileAccess {
  id        String         @id @default(cuid())
  userId    String
  nodeId    String         // 关联到FileSystemNode
  role      FileAccessRole @default(VIEWER)
  createdAt DateTime       @default(now())

  // 关联关系
  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  node FileSystemNode   @relation("NodeAccesses", fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([userId, nodeId])
  @@map("file_accesses")
}

model Asset {
  id          String     @id @default(cuid())
  name        String
  description String?
  category    String
  path        String
  thumbnail   String?
  size        Int
  mimeType    String
  status      AssetStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("assets")
}

model Font {
  id          String    @id @default(cuid())
  name        String
  family      String
  path        String
  size        Int
  status      FontStatus @default(ACTIVE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("fonts")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// 枚举类型
enum UserRole {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum ProjectMemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum FileStatus {
  UPLOADING
  PROCESSING
  COMPLETED
  FAILED
  DELETED
}

enum FileAccessRole {
  OWNER
  EDITOR
  VIEWER
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum FontStatus {
  ACTIVE
  INACTIVE
  DELETED
}
