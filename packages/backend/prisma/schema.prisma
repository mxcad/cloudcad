generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  nickname  String?
  avatar    String?
  role      UserRole @default(USER)
  status    UserStatus @default(INACTIVE)
  emailVerified    Boolean  @default(false)
  emailVerifiedAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联关系
  ownedNodes         FileSystemNode[] @relation("NodeOwner")
  nodeAccesses       FileAccess[]

  @@map("users")
}

// ============ 文件系统统一模型 ============
model FileSystemNode {
  id          String   @id @default(cuid())
  name        String
  isFolder    Boolean  @default(false)  // true=文件夹, false=文件
  isRoot      Boolean  @default(false)  // true=项目根目录
  
  // 树形结构（自引用）
  parentId    String?
  parent      FileSystemNode?  @relation("NodeHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    FileSystemNode[] @relation("NodeHierarchy")
  
  // 文件专属字段（文件夹时为null）
  originalName String?   // 原始文件名
  path         String?   // 文件访问路径（如：/mxcad/file/xxx.dwg.mxweb）
  size         Int?      // 文件大小（字节）
  mimeType     String?   // MIME类型
  extension    String?   // 文件扩展名（.dwg, .dxf）
  fileStatus   FileStatus? // 文件状态
  fileHash     String?   // 文件SHA-256哈希值（用于去重）
  
  // 项目专属字段（仅根节点使用）
  description    String?          // 项目描述
  projectStatus  ProjectStatus?   // 项目状态
  
  // 权限与审计
  ownerId     String
  owner       User     @relation("NodeOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime? // 软删除时间（回收站功能）

  // 关联关系
  nodeAccesses FileAccess[]    @relation("NodeAccesses")
  
  // 索引优化
  @@index([parentId])
  @@index([ownerId])
  @@index([isRoot])
  @@index([isFolder])
  @@index([deletedAt])
  @@map("file_system_nodes")
}

model FileAccess {
  id        String         @id @default(cuid())
  userId    String
  nodeId    String         // 关联到FileSystemNode
  role      FileAccessRole @default(VIEWER)
  createdAt DateTime       @default(now())

  // 关联关系
  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  node FileSystemNode   @relation("NodeAccesses", fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([userId, nodeId])
  @@map("file_accesses")
}

model Asset {
  id          String     @id @default(cuid())
  name        String
  description String?
  category    String
  path        String
  thumbnail   String?
  size        Int
  mimeType    String
  status      AssetStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("assets")
}

model Font {
  id          String    @id @default(cuid())
  name        String
  family      String
  path        String
  size        Int
  status      FontStatus @default(ACTIVE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("fonts")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model UploadSession {
  id          String   @id @default(cuid())
  uploadId    String   @unique  // MinIO返回的上传ID
  storageKey  String   // 存储键名
  fileName    String   // 原始文件名
  fileSize    Int      // 文件总大小
  fileId      String?  // 关联的文件ID（完成后设置）
  projectId   String?  // 项目ID
  parentId    String?  // 父节点ID
  ownerId     String   // 上传者ID
  status      String   @default("INITIATED") // INITIATED, UPLOADING, COMPLETED, FAILED, ABORTED
  totalParts  Int?     // 总分片数
  uploadedParts Int    @default(0) // 已上传分片数
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("upload_sessions")
}

// 枚举类型
enum UserRole {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum FileStatus {
  UPLOADING
  PROCESSING
  COMPLETED
  FAILED
  DELETED
}

enum FileAccessRole {
  OWNER      // 所有者：完全控制
  ADMIN      // 管理员：管理权限
  MEMBER     // 成员：可编辑
  EDITOR     // 编辑者：可编辑文件
  VIEWER     // 查看者：只读
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum FontStatus {
  ACTIVE
  INACTIVE
  DELETED
}
