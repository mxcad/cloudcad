{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>"],
  "testMatch": ["**/src/test/integration/project-member.integration.spec.ts"],
  "testPathIgnorePatterns": ["/node_modules/", "/dist/"],
  "transform": {
    "^.+\\.ts$": ["ts-jest", { "tsconfig": "tsconfig.json" }]
  },
  "testTimeout": 60000,
  "forceExit": true
}
