{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "pnpm exec nest start --watch",
    "build": "pnpm exec nest build",
    "start": "node dist/src/main",
    "start:prod": "node dist/src/main",
    "lint": "pnpm exec eslint . --ext .js,.ts",
    "lint:fix": "pnpm exec eslint . --ext .js,.ts --fix",
    "format": "pnpm exec prettier --write .",
    "format:check": "pnpm exec prettier --check .",
    "check": "pnpm lint && pnpm format:check && pnpm type-check",
    "check:fix": "pnpm lint:fix && pnpm format && pnpm type-check",
    "type-check": "pnpm exec tsc --noEmit --project tsconfig.build.json",
    "verify": "pnpm check:fix && pnpm test && pnpm build",
    "test": "pnpm exec jest",
    "test:watch": "pnpm exec jest --watch",
    "test:cov": "pnpm exec jest --coverage",
    "test:unit": "pnpm exec jest --testPathIgnorePatterns=integration",
    "test:integration": "pnpm exec jest --testPathPatterns=integration --forceExit",
    "test:all": "pnpm exec jest --verbose --forceExit",
    "test:e2e": "pnpm exec jest --config ./test/jest-e2e.json",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "test:ci": "pnpm exec jest --coverage --ci --watchAll=false",
    "test:permission": "pnpm exec jest --testPathPatterns=permission --testNamePattern=\"PermissionTestRunner\"",
    "test:permission:scenarios": "pnpm exec jest --testPathPatterns=permission-scenarios",
    "db:generate": "pnpm exec prisma generate",
    "db:push": "pnpm exec prisma db push",
    "db:migrate": "pnpm exec prisma migrate dev",
    "db:studio": "pnpm exec prisma studio",
    "db:seed": "pnpm exec ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@cloudcad/svn-version-tool": "workspace:*",
    "@css-inline/css-inline": "^0.20.1",
    "@nestjs-modules/ioredis": "^2.0.2",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@paralleldrive/cuid2": "^3.0.4",
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "connect-redis": "^9.0.0",
    "express": "^5.2.1",
    "express-session": "^1.18.2",
    "graphmatch": "^1.1.1",
    "handlebars": "^4.7.8",
    "ioredis": "^5.8.2",
    "is-unicode-supported": "^2.1.0",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.11",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^7.1.0",
    "redis": "^5.10.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/ioredis": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "ajv": "^8.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^30.0.0",
    "node-loader": "^2.0.0",
    "prettier": "^3.2.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
