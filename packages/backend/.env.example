# CloudCAD Backend 环境配置
# 复制此文件为 .env 并修改配置
# copy .env.example .env

# ============================================
# 应用配置
# ============================================

PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ============================================
# 数据库配置
# ============================================

# Prisma 连接字符串 (必须配置)
# 本地开发: postgresql://postgres:password@localhost:5432/cloudcad
# Docker 部署: postgresql://postgres:your-secure-password-here@postgres:5432/cloudcad
DATABASE_URL=postgresql://postgres:password@localhost:5432/cloudcad

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_DATABASE=cloudcad
DB_SSL=false
DB_MAX_CONNECTIONS=20
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=30000

# ============================================
# Redis 配置
# ============================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=100
REDIS_CONNECT_TIMEOUT=10000

# ============================================
# JWT 配置
# ============================================

# JWT 密钥 (生产环境必须修改!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# Session 配置
# ============================================

# Session 密钥 (可选，默认使用 JWT_SECRET)
SESSION_SECRET=
# Session 有效期 (毫秒，默认 24 小时)
SESSION_MAX_AGE=86400000
# Session Cookie 名称
SESSION_NAME=mxcad.sid

# ============================================
# 存储路径配置
# ============================================
# 重要: 建议使用绝对路径，相对路径是相对于当前整个项目的根目录,而非后端项目目录
# Windows 示例: D:/web/MxCADOnline/cloudcad/filesData
# Linux 示例: /var/www/cloudcad/filesData

# 文件数据目录 (存储 CAD 文件、缩略图等)
FILES_DATA_PATH=filesData

# SVN 仓库目录
SVN_REPO_PATH=svn-repo

# 单目录最大节点数 (默认 300000)
FILES_NODE_LIMIT=300000

# SVN 忽略的文件模式 (逗号分隔)
# 这些文件不会被提交到 SVN 版本控制
SVN_IGNORE_PATTERNS=*.mxweb,*.dwg,*.dxf,*.json,*.jpg

# ============================================
# 上传配置
# ============================================
# 注意: 文件大小限制 (maxFileSize) 已迁移到运行时配置系统，可在管理界面动态修改
# Multer 中间件层使用固定上限值 (500MB)，业务层使用运行时配置进行精确限制
# 其他上传配置仍需要在此处设置

# 允许的文件类型 (逗号分隔)
UPLOAD_ALLOWED_TYPES=.dwg,.dxf,.pdf,.png,.jpg,.jpeg
# 单次上传最大文件数
UPLOAD_MAX_FILES=10
# 允许的 CAD 文件扩展名 (用于严格验证)
UPLOAD_ALLOWED_EXTENSIONS=.dwg,.dxf
# 禁止上传的文件扩展名
UPLOAD_BLOCKED_EXTENSIONS=.exe,.bat,.sh,.cmd,.ps1

# ============================================
# MxCAD 转换服务配置
# ============================================
# 重要: 路径必须使用绝对路径或确保相对路径能正确解析

# MxCAD 转换程序路径
MXCAD_ASSEMBLY_PATH=runtime/windows/mxcad/mxcadassembly.exe

# 上传临时目录
MXCAD_UPLOAD_PATH=uploads

# 临时文件目录
MXCAD_TEMP_PATH=temp

# 字体目录 (可选)
MXCAD_FONTS_PATH=runtime/windows/mxcad/fonts

# 前端字体目录 (可选)
# 用于存储前端 Web 显示所需的字体文件
# 默认指向 frontend/dist/mxcadAppAssets/fonts
FRONTEND_FONTS_PATH=runtime/windows/mxcad/fonts

MXCAD_FILE_EXT=.mxweb
MXCAD_COMPRESSION=true

# ============================================
# 缓存配置
# ============================================

# L2 缓存默认 TTL (秒，默认 30 分钟)
CACHE_L2_DEFAULT_TTL=1800
# 缓存版本最大有效期 (毫秒，默认 1 小时)
CACHE_VERSION_MAX_AGE=3600000

# ============================================
# 缓存 TTL 配置 (秒)
# ============================================

# 验证码有效期 (默认 15 分钟)
CACHE_TTL_VERIFICATION_CODE=900
# 验证码限流周期 (默认 1 分钟)
CACHE_TTL_VERIFICATION_RATE_LIMIT=60
# Token 黑名单有效期 (默认 7 天)
CACHE_TTL_TOKEN_BLACKLIST=604800
# 缓存版本有效期 (默认 24 小时)
CACHE_TTL_CACHE_VERSION=86400
# 默认缓存 TTL (默认 5 分钟)
CACHE_TTL_DEFAULT=300
# MxCAD 缓存 TTL (默认 5 分钟)
CACHE_TTL_MXCAD=300
# 权限缓存 TTL (默认 5 分钟)
CACHE_TTL_PERMISSION=300
# 策略缓存 TTL (默认 10 分钟)
CACHE_TTL_POLICY=600

# ============================================
# 文件扩展名配置 (逗号分隔)
# ============================================

# CAD 文件扩展名
FILE_EXT_CAD=.dwg,.dxf
# 图片文件扩展名
FILE_EXT_IMAGE=.png,.jpg,.jpeg,.gif,.bmp,.svg,.webp
# 文档文件扩展名
FILE_EXT_DOCUMENT=.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt
# 压缩文件扩展名
FILE_EXT_ARCHIVE=.zip,.rar,.7z,.tar,.gz
# 字体文件扩展名
FILE_EXT_FONT=.ttf,.otf,.woff,.woff2,.eot,.shx
# 禁止上传的扩展名
FILE_EXT_FORBIDDEN=.exe,.bat,.sh,.cmd,.ps1,.scr,.vbs

# ============================================
# 文件限制配置
# ============================================

# ZIP 解压最大总大小 (字节，默认 2GB)
FILE_LIMIT_ZIP_MAX_TOTAL_SIZE=2147483648
# ZIP 解压最大文件数
FILE_LIMIT_ZIP_MAX_FILE_COUNT=10000
# ZIP 解压最大深度
FILE_LIMIT_ZIP_MAX_DEPTH=50
# ZIP 解压单文件最大大小 (字节，默认 500MB)
FILE_LIMIT_ZIP_MAX_SINGLE_FILE_SIZE=524288000
# ZIP 压缩级别 (1-9)
FILE_LIMIT_ZIP_COMPRESSION_LEVEL=1
# 最大文件名长度
FILE_LIMIT_MAX_FILENAME_LENGTH=255
# 最大路径长度
FILE_LIMIT_MAX_PATH_LENGTH=1024
# 最大目录深度
FILE_LIMIT_MAX_DIRECTORY_DEPTH=10
# 最大递归深度
FILE_LIMIT_MAX_RECURSION_DEPTH=50
# 角色继承最大深度
FILE_LIMIT_MAX_HIERARCHY_DEPTH=50

# ============================================
# 分页配置
# ============================================

# 默认页大小
PAGINATION_DEFAULT_PAGE_SIZE=50
# 最大页大小
PAGINATION_MAX_PAGE_SIZE=100

# ============================================
# 超时配置 (毫秒)
# ============================================

# 文件转换超时
TIMEOUT_FILE_CONVERSION=60000
# 分布式锁超时
TIMEOUT_DISTRIBUTED_LOCK=5000
# 请求限流超时
TIMEOUT_RATE_LIMITER=600000
# 目录分配节点限制超时
TIMEOUT_DIRECTORY_ALLOCATOR=300000

# ============================================
# 产品信息配置
# ============================================

# 产品名称
PRODUCT_NAME=CloudCAD
# 默认发件人
PRODUCT_DEFAULT_SENDER=CloudCAD <noreply@cloudcad.com>

# ============================================
# 缓存预热配置
# ============================================

# 最大预热用户数
CACHE_WARMUP_MAX_USERS=100
# 最大预热项目数
CACHE_WARMUP_MAX_PROJECTS=50

# ============================================
# 文件锁配置
# ============================================

# 锁超时时间 (毫秒，默认 5 分钟)
FILE_LOCK_TIMEOUT=300000
# 获取锁重试间隔 (毫秒)
FILE_LOCK_RETRY_INTERVAL=100
# 最大重试次数
FILE_LOCK_MAX_RETRIES=3

# ============================================
# 邮件服务配置
# ============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM=CloudCAD <your-email@gmail.com>

# ============================================
# 初始管理员账户 (仅在首次启动时创建)
# ============================================

INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=Admin123!