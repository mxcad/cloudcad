# 应用配置
PORT=3001
NODE_ENV=development

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_DATABASE=cloucad
DB_SSL=false
DB_MAX_CONNECTIONS=20
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=30000

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=100

# 文件上传配置
UPLOAD_MAX_SIZE=104857600
UPLOAD_ALLOWED_TYPES=.dwg,.dxf,.pdf,.png,.jpg,.jpeg

# 本地存储路径
FILES_DATA_PATH=../filesData

# SVN 版本控制配置
SVN_REPO_PATH=../svn-repo

# MxCAD 转换服务配置
# ============================================
# Windows 平台示例：
MXCAD_ASSEMBLY_PATH=D:\web\MxCADOnline\cloudcad\packages\mxcadassembly\windows\release\mxcadassembly.exe
# Linux 平台示例（部署时取消注释并修改路径）：
# MXCAD_ASSEMBLY_PATH=/opt/cloudcad/mxcadassembly/linux/release/mxcadassembly
# ============================================
# 注意：Linux 平台首次部署需要执行以下命令：
#   cd /opt/cloudcad/mxcadassembly/linux/release
#   sudo chmod -R 777 mxcadassembly
#   sudo chmod -R 777 ./mx/so/*
#   sudo cp -r -f ./mx/locale /usr/local/share/locale
# 或者启动项目时会自动尝试初始化（可能需要 sudo 权限）
# ============================================
MXCAD_UPLOAD_PATH=D:\web\MxCADOnline\cloudcad\uploads
MXCAD_TEMP_PATH=D:\web\MxCADOnline\cloudcad\temp
MXCAD_FILE_EXT=.mxweb
MXCAD_COMPRESSION=true

# 字体文件目录配置
# ============================================
# Windows 平台示例（默认值）：
# MXCAD_FONTS_PATH=D:\web\MxCADOnline\cloudcad\packages\mxcadassembly\windows\release\fonts
# Linux 平台示例（部署时取消注释并修改路径）：
# MXCAD_FONTS_PATH=/opt/cloudcad/mxcadassembly/linux/release/fonts
# ============================================
# 注意：如果不配置，系统会根据平台自动选择默认路径
# ============================================

# 邮件服务配置
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM=CloudCAD <noreply@cloucad.com>

# 前端地址
FRONTEND_URL=http://localhost:3000

# 初始管理员账户配置（仅在首次启动时创建）
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=Admin123!