{
  "name": "frontend_mobile",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "dev-force": "vite --host --force",
    "build": "pnpm setDefaultI18n && pnpm i18nCompile && vite build",
    "build:en": "pnpm setEnI18n && pnpm i18nCompile && vite build",
    "preview": "vite preview",
    "generate:sdk": "node scripts/generate-sdk.cjs",
    "type-check": "vue-tsc --noEmit",
    "clean": "rimraf dist",
    "iconReplace": "node iconReplace.js",
    "setEnI18n": "voerkai18n init . -lngs en -d en -r",
    "setDefaultI18n": "voerkai18n init . -lngs zh en cht -d zh -r",
    "i18nInit": "pnpm setDefaultI18n",
    "i18nExtract": "voerkai18n extract -D -f ts,vue,json -e !dist,!.vscode,!doc,!patches,!public,!scripts",
    "i18nAutoTranslate": "voerkai18n translate --appid 20230922001825895 --appkey UeUQKzvpZgp_wkyh5dyi",
    "i18nCompile": "voerkai18n compile -t",
    "i18n": "node scripts/i18n/index.cjs",
    "i18nAnnotationTranslation": "node scripts/i18n/i18nAnnotationTranslation",
    "i18nSourceCodeSubstitution-ZH": "node scripts/i18n/i18nSourceCodeSubstitution.js -d zh",
    "i18nSourceCodeSubstitution-EN": "node scripts/i18n/i18nSourceCodeSubstitution.js -d en",
    "postinstall": ""
  },
  "dependencies": {
    "@better-scroll/core": "^2.5.1",
    "@better-scroll/observe-dom": "^2.5.1",
    "@better-scroll/observe-image": "^2.5.1",
    "@jaames/iro": "^5.5.2",
    "@vant/touch-emulator": "^1.4.0",
    "@varlet/touch-emulator": "^2.9.3",
    "@voerkai18n/runtime": "^2.1.10",
    "@voerkai18n/vue": "^2.1.10",
    "@vueuse/core": "^10.9.0",
    "axios": "^1.13.2",
    "latest": "^0.2.0",
    "mxcad": "latest",
    "mxdraw": "latest",
    "spark-md5": "^3.0.2",
    "vant": "^4.9.24",
    "vue": "^3.2.47"
  },
  "devDependencies": {
    "@hey-api/client-fetch": "^0.13.1",
    "@hey-api/openapi-ts": "^0.97.1",
    "@types/node": "^22.14.0",
    "@types/spark-md5": "^3.0.5",
    "@vitejs/plugin-legacy": "1.8.2",
    "@vitejs/plugin-vue": "^4.1.0",
    "@vitejs/plugin-vue-jsx": "^3.0.1",
    "@voerkai18n/cli": "^2.1.10",
    "@voerkai18n/vite": "^2.1.10",
    "lib-flexible": "^0.3.2",
    "node-html-parser": "^6.1.5",
    "patch-package": "^8.0.0",
    "postcss-pxtorem": "^6.0.0",
    "sass": "^1.60.0",
    "terser": "5.14.2",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^0.17.5",
    "unplugin-vue-components": "^32.1.0",
    "vconsole": "^3.15.0",
    "vite": "^4.2.1",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-vconsole": "^1.3.1",
    "vue-tsc": "^2.0.0"
  }
}
