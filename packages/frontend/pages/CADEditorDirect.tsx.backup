import React, { useEffect } from 'react';
import { useNavigate, useLocation } from 'react-router-dom';
import { ArrowLeft } from 'lucide-react';
import 'mxcad-app/style';
import { useAuth } from '../contexts/AuthContext';
import { 
  useMxCadConfig, 
  useProjectContext, 
  
  useMxCadServerConfig 
} from '../hooks/useMxCadEditor';
import { useMxCadInstance, useFileOpening } from '../hooks/useMxCadInstance';
import { UrlHelper, Logger } from '../utils/mxcadUtils';

// 全局类型定义
declare global {
  interface Window {
    mxcadAppContext?: {
      userId: string;
      projectId: string;
      parentId?: string;
      userRole: string;
    };
  }
}

interface CADEditorDirectProps {
  fileUrl?: string;
}

export const CADEditorDirect: React.FC<CADEditorDirectProps> = ({ fileUrl }) => {
  const navigate = useNavigate();
  const location = useLocation();
  const { user } = useAuth();
  
  // 从 URL 参数获取文件 ID
  const urlFileId = UrlHelper.getFileIdFromPath(location.pathname) || fileUrl;
  
  Logger.info('组件渲染', { fileUrl, urlFileId, path: location.pathname });

  // 使用自定义 hooks 管理各个关注点
  const { configInitialized } = useMxCadConfig();
  const projectContext = useProjectContext();
 
  const { setupServerConfig } = useMxCadServerConfig(user, projectContext);
  
  const { isMxCADReady, initializeMxCAD, showMxCAD } = useMxCadInstance(urlFileId);
  const { openFile } = useFileOpening(isMxCADReady, urlFileId);

  // 初始化 MxCAD
  useEffect(() => {
    if (configInitialized) {
      initializeMxCAD();
    }
  }, [configInitialized, initializeMxCAD]);

  // 组件挂载/卸载时显示/隐藏 MxCAD
  useEffect(() => {
    const setupAndShow = async () => {
      showMxCAD(true);
      Logger.info('显示 MxCAD 容器');
      await setupServerConfig();
    };

    setupAndShow();

    return () => {
      showMxCAD(false);
      Logger.info('隐藏 MxCAD 容器（保持实例）');
    };
  }, [showMxCAD, setupServerConfig]);

  // 文件切换
  useEffect(() => {
    if (isMxCADReady && urlFileId) {
      openFile();
    }
  }, [urlFileId, isMxCADReady, openFile]);

  if (!configInitialized) {
    return (
      <div className="flex flex-col items-center justify-center h-full text-slate-500">
        <div className="animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600"></div>
        <p className="mt-4">正在初始化 CAD 编辑器...</p>
      </div>
    );
  }

  if (!isMxCADReady) {
    return (
      <div className="flex flex-col items-center justify-center h-full text-slate-500">
        <div className="animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600"></div>
        <p className="mt-4">正在加载 MxCAD 引擎...</p>
      </div>
    );
  }

  return (
    <div
      style={{
        width: '100%',
        height: '100vh',
        position: 'relative',
      }}
    >
      {/* 返回按钮 */}
      <button
        onClick={() => navigate('/projects')}
        className="fixed top-4 left-4 z-[9999] flex items-center gap-2 px-4 py-2 bg-white border border-slate-300 rounded-md shadow-sm hover:bg-slate-50 text-sm font-medium text-slate-700"
      >
        <ArrowLeft size={16} />
        返回项目列表
      </button>

      {/* MxCAD 现在使用全局容器，这里不需要本地容器 */}
      {/* 全局容器由 mxcadManager 自动创建和管理 */}
    </div>
  );
};