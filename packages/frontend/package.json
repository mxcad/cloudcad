{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm lint && pnpm format:check",
    "check:fix": "pnpm lint:fix && pnpm format",
    "type-check": "tsc --noEmit",
    "generate:sdk": "npx @hey-api/openapi-ts",
    "setDefaultI18n": "voerkai18n init . -lngs zh en cht -d zh -r --library",
    "i18n:init": "pnpm setDefaultI18n",
    "i18n:extract": "voerkai18n extract -D -f ts,tsx,json -e !dist,!node_modules,!coverage",
    "i18n:compile": "voerkai18n compile -t",
    "i18n": "pnpm i18n:init && pnpm i18n:extract && pnpm i18n:compile"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.100.9",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.556.0",
    "mxcad-app": "^1.0.45",
    "openapi-client-axios": "^7.5.5",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.68.0",
    "react-horizontal-scrolling": "^0.1.13",
    "react-router-dom": "^7.10.1",
    "recharts": "^3.5.1",
    "spark-md5": "^3.0.2",
    "tailwind-merge": "^3.4.0",
    "webuploader": "^0.1.8",
    "zod": "^4.2.1",
    "@voerkai18n/react": "^2.1.10",
    "@voerkai18n/runtime": "^2.1.10",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@hey-api/client-fetch": "^0.13.1",
    "@hey-api/openapi-ts": "^0.98.2",
    "@msw/source": "^0.6.1",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/spark-md5": "^3.0.5",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "^4.1.8",
    "autoprefixer": "^10.4.23",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "happy-dom": "^20.10.2",
    "jsdom": "^29.1.1",
    "msw": "^2.14.3",
    "msw-auto-mock": "^0.32.1",
    "openapicmd": "^2.9.2",
    "postcss": "^8.5.6",
    "prettier": "^3.2.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "@voerkai18n/cli": "^3.0.22",
    "@voerkai18n/vite": "^2.1.10",
    "vitest": "^4.1.8"
  }
}
