# Node.js 完整工具验证 Dockerfile
# 测试 pm2, pnpm, npx 是否正常工作

FROM debian:bullseye-slim

RUN mkdir -p /opt/node
COPY --from=node / /opt/node/

ENV PATH="/opt/node/bin:${PATH}"
ENV LD_LIBRARY_PATH="/opt/node/lib"

# 修复路径
RUN cd /opt/node/lib && ln -s node_modules/npm/lib/cli.js cli.js 2>/dev/null || true

# 设置 corepack 模块路径
ENV COREPACK_ROOT="/opt/node/lib/node_modules/corepack"

RUN echo '#!/bin/sh' > /verify.sh && \
    echo 'echo "=== Node.js 完整工具验证 ==="' >> /verify.sh && \
    echo 'echo ""' >> /verify.sh && \
    echo 'echo "1. node --version:"' >> /verify.sh && \
    echo '/opt/node/bin/node --version' >> /verify.sh && \
    echo 'echo ""' >> /verify.sh && \
    echo 'echo "2. npm --version:"' >> /verify.sh && \
    echo '/opt/node/bin/npm --version' >> /verify.sh && \
    echo 'echo ""' >> /verify.sh && \
    echo 'echo "3. npx --version:"' >> /verify.sh && \
    echo '/opt/node/bin/npx --version || echo "npx 需要 npm"' >> /verify.sh && \
    echo 'echo ""' >> /verify.sh && \
    echo 'echo "4. corepack --version:"' >> /verify.sh && \
    echo '/opt/node/bin/node /opt/node/lib/node_modules/corepack/dist/corepack.js --version || echo "corepack 路径问题"' >> /verify.sh && \
    echo 'echo ""' >> /verify.sh && \
    echo 'echo "5. pnpm (via node):"' >> /verify.sh && \
    echo 'cd /tmp && /opt/node/bin/node /opt/node/lib/node_modules/corepack/dist/corepack.js pnpm --version || echo "pnpm 需要 corepack"' >> /verify.sh && \
    echo 'echo ""' >> /verify.sh && \
    echo 'echo "6. pm2 --version:"' >> /verify.sh && \
    echo '/opt/node/bin/node /opt/node/lib/node_modules/pm2/bin/pm2 --version || echo "pm2"' >> /verify.sh && \
    echo 'echo ""' >> /verify.sh && \
    echo 'echo "=== 验证完成 ==="' >> /verify.sh && \
    chmod +x /verify.sh

CMD ["/verify.sh"]
