{
  "name": "cloudcad",
  "version": "1.0.0",
  "description": "CloudCAD monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm lint ; pnpm format:check ; pnpm type-check",
    "check:fix": "pnpm lint:fix ; pnpm format",
    "type-check": "pnpm -r type-check",
    "clean": "pnpm -r clean",
    "cooperate": "node runtime/scripts/cooperate-manager.js",
    "generate:frontend-permissions": "node scripts/generate-frontend-permissions.js",
    "generate:api-types": "node scripts/generate-api-types.js",
    "generate:tour-docs": "tsx scripts/generate-tour-docs.ts",
    "pack:offline": "node scripts/pack-offline.js --deploy",
    "pack:offline:win": "node scripts/pack-offline.js --win --deploy",
    "pack:offline:linux": "node scripts/pack-offline.js --linux --deploy",
    "pack:offline:all": "node scripts/pack-offline.js --all",
    "pack:linux-deploy": "node scripts/pack-linux-deploy.js",
    "verify:linux": "node scripts/verify-linux-deploy.js",
    "verify:linux:debian": "node scripts/verify-linux-deploy.js --os debian",
    "verify:linux:ubuntu22": "node scripts/verify-linux-deploy.js --os ubuntu22",
    "verify:linux:ubuntu24": "node scripts/verify-linux-deploy.js --os ubuntu24",
    "verify:linux:centos7": "node scripts/verify-linux-deploy.js --os centos7",
    "verify:linux:rocky8": "node scripts/verify-linux-deploy.js --os rocky8",
    "verify:linux:rocky9": "node scripts/verify-linux-deploy.js --os rocky9",
    "deploy": "docker-compose -f docker/docker-compose.yml --env-file docker/.env up -d --build",
    "deploy:down": "docker-compose -f docker/docker-compose.yml down",
    "deploy:reset": "docker-compose -f docker/docker-compose.yml down -v",
    "deploy:logs": "docker-compose -f docker/docker-compose.yml logs -f",
    "deploy:rebuild": "docker-compose -f docker/docker-compose.yml build --no-cache"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "effect": "^3.21.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "prettier": "^3.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=20.19.5",
    "pnpm": ">=9.15.9"
  },
  "packageManager": "pnpm@9.15.9"
}
